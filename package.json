{
  "name": "easy-shell",
  "version": "0.2.0",
  "private": true,
  "description": "Easy Shell - a simple SSH client",
  "main": "./out/main/index.js",
  "productName": "Easy Shell",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "dist:win": "npm run build && electron-builder --win --x64 --ia32",
    "dist": "npm run build && electron-builder --mac --x64 --arm64 --win --x64 --ia32"
  },
  "build": {
    "appId": "com.easyshell.app",
    "productName": "Easy Shell",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64", "ia32"]
        }
      ]
    }
  },
  "dependencies": {
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^31.3.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
